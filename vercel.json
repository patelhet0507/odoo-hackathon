{
  "buildCommand": "python manage.py collectstatic --noinput && python manage.py migrate --noinput",
  "installCommand": "pip install -r requirements.txt",
  "outputDirectory": "staticfiles",
  "functions": {
    "api/index.py": {
      "maxDuration": 30,
      "memory": 512
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index.py" }
  ]
}
